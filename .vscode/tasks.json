{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Lectio",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe -m uvicorn main:app --reload --reload-exclude .venv --host 0.0.0.0",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
