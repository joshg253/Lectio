# Lectio container env. Copy to .env on the VPS and fill in real values.
# Compose interpolates ${BASE_URL} and ${TZ} at deploy time.

# Traefik routing host: lectio.${BASE_URL}
BASE_URL=example.com
TZ=America/Los_Angeles

# Security mode: single (default) or multi.
#   single - one user; LECTIO_USERNAME/PASSWORD below gate the login.
#   multi  - multi-user with isolated per-user databases. Accounts live in a
#            users table; first startup seeds the admin below.
LECTIO_SECURITY_MODE=single

# Single-mode auth (both required to enable the login gate). Ignored in multi mode.
LECTIO_USERNAME=
LECTIO_PASSWORD=

# Multi-mode bootstrap admin, created on first startup when no users exist.
# CHANGE THE PASSWORD before exposing the instance. Used only when SECURITY_MODE=multi.
LECTIO_ADMIN_USERNAME=admin
LECTIO_ADMIN_PASSWORD=ChangeA$ap

# Password hashing scheme for stored credentials (multi mode):
#   scrypt (default, stdlib) | pbkdf2_sha256 (stdlib) | argon2 (needs argon2-cffi)
LECTIO_PASSWORD_HASH_SCHEME=scrypt

# Required when AUTH is enabled (single OR multi). Generate with: python -c "import secrets; print(secrets.token_hex(32))"
LECTIO_SECRET_KEY=

# Fever API password. Set to enable the Fever-compatible API for RSS clients
# (Reeder, FeedMe, etc.). Use a dedicated password — NOT your main Lectio
# password — since Fever auth uses MD5. Configure clients with your Lectio
# username and this password.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
LECTIO_FEVER_PASSWORD=

# Optional: YouTube Data API v3 key. If set, video durations come from the
# API; if unset, Lectio falls back to scraping the watch page.
YOUTUBE_API_KEY=

# YouTube subscription sync. Set YOUTUBE_CHANNEL_ID to your channel handle
# (@name), username, or raw channel ID (UCxxxxxx). The channel's subscriptions
# must be set to Public on YouTube (Manage all subscriptions > Settings).
# YOUTUBE_FOLDER_NAME defaults to "YouTube Subscriptions" if unset.
# YOUTUBE_SYNC_HOUR: hour of day (0–23, local time) for auto-sync; leave blank
# to disable scheduled sync (right-click "Update Feeds" still works).
YOUTUBE_CHANNEL_ID=
YOUTUBE_FOLDER_NAME=YouTube Subscriptions
YOUTUBE_SYNC_HOUR=

# Resend email integration. Set RESEND_API_KEY to enable the "Email Article" share button.
# LECTIO_EMAIL_FROM must be a verified Resend sender address.
# LECTIO_EMAIL_TO is the default recipient; can be changed per-send in the UI.
RESEND_API_KEY=
LECTIO_EMAIL_FROM=
LECTIO_EMAIL_TO=

# Enable built-in dev/test feeds (email-match, email-skip — RSS/Atom/JSON)
# LECTIO_DEBUG=1

# Public origin of this instance (scheme + host, no trailing slash, e.g.
# https://lectio.example.com). Used to build OAuth redirect URIs (DeviantArt
# connect) and WebSub callbacks so they match exactly. Leave blank to fall back
# to the request host (and to disable WebSub).
LECTIO_PUBLIC_URL=

# Reverse proxy / security headers (the bundled Traefik config sets HTTPS_ONLY
# and security headers for you; set these when fronting Lectio with a different
# proxy or none).
# LECTIO_HTTPS_ONLY=1
# LECTIO_TRUSTED_PROXIES=*            # or a comma-separated allowlist of proxy IPs
# LECTIO_SECURITY_HEADERS=1           # emit HSTS/nosniff/frameDeny/referrer from the app

# DeviantArt API (galleries). Credentials are normally set PER USER under
# Settings → Integrations; these env vars are a single-user-only fallback and are
# ignored when multi-user auth is enabled. Register an app at
# https://www.deviantart.com/developers/ to obtain a Client ID + Secret.
DEVIANTART_CLIENT_ID=
DEVIANTART_CLIENT_SECRET=

# YouTube Data API v3 OAuth (write access for "Add to playlist"). The read-only
# YOUTUBE_API_KEY (durations, sub-sync) is separate. Create an OAuth 2.0 Client ID
# (type "Web application") in Google Cloud with redirect URI
# https://<your-host>/youtube/oauth/callback, scope
# https://www.googleapis.com/auth/youtube. The per-user refresh token is stored in
# the user's meta DB after they connect; these are the app-level client creds.
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=

# Pinterest OAuth (per-entry "Pin" button — save an article to a board). App-level
# client creds from a Pinterest app (https://developers.pinterest.com/) with
# redirect URI https://<your-host>/integrations/pinterest/oauth/callback and
# scopes boards:read,pins:write. The per-user refresh token is stored in the
# user's meta DB after they connect.
PINTEREST_OAUTH_CLIENT_ID=
PINTEREST_OAUTH_CLIENT_SECRET=

# /api/img proxy cache (server-side cache of fetched article images). These are
# instance-level fallbacks; admins can override them in the Administration page.
#   LECTIO_IMG_CACHE_DAYS    evict entries not viewed within N days; 0 = keep forever
#   LECTIO_IMG_CACHE_MAX_DIM downscale stored images to this longest-side px; 0 = originals
LECTIO_IMG_CACHE_DAYS=90
LECTIO_IMG_CACHE_MAX_DIM=3840

# Feed fetch-history retention (Feed Properties → History tab). Pruned nightly.
#   LECTIO_FETCH_HISTORY_KEEP          max rows kept per feed
#   LECTIO_FETCH_HISTORY_MAX_AGE_DAYS  drop rows older than N days regardless
LECTIO_FETCH_HISTORY_KEEP=50
LECTIO_FETCH_HISTORY_MAX_AGE_DAYS=30

# Optional tuning
# LECTIO_SESSION_MAX_AGE=31536000
# LECTIO_LOGIN_MAX_FAILURES=5
# LECTIO_LOGIN_WINDOW_SECONDS=300
# LECTIO_AUTO_REFRESH_MINUTES=60
