# Lectio container env — only what's needed to start the app and bootstrap the admin.
# Integration credentials (YouTube, Pinterest, Quire, Resend, etc.) are configured
# in the UI: Settings (per-user) or Administration (shared instance).
# Tuning (login limits, feed history, refresh defaults) is in Administration → Instance config.

# Traefik routing host: lectio.${BASE_URL}
# LECTIO_PUBLIC_URL is derived from BASE_URL in docker-compose.yml — no need to set it here.
BASE_URL=catfork.win
TZ=America/Los_Angeles

# Bootstrap admin, created on first startup when no users exist.
# CHANGE THE PASSWORD before exposing the instance.
LECTIO_ADMIN_USERNAME=joshg253
LECTIO_ADMIN_PASSWORD=eFPkWDdjLG8cok

# Password hashing scheme: scrypt (default) | pbkdf2_sha256 | argon2
LECTIO_PASSWORD_HASH_SCHEME=scrypt

# Auto-login: skip the login form and authenticate as admin automatically.
# Use only on private/local-network installs where a password prompt isn't needed.
# LECTIO_AUTO_LOGIN=1

# Required when auth is enabled. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
LECTIO_SECRET_KEY=64592acf93a2db13e5120e27ca890a364670a749e746fff4af20c998f81a3c96

# Enable built-in dev/test feeds (email-match, email-skip — RSS/Atom/JSON)
LECTIO_DEBUG=0

# Reverse proxy / security headers (Traefik in docker-compose already sets these)
# LECTIO_TRUSTED_PROXIES=*
# LECTIO_SECURITY_HEADERS=1

# Kill switch: skip scheduled refresh and backfill on startup (ops use only)
# LECTIO_DISABLE_STARTUP_BACKFILL=1
